# GroupScout .env example

# Database
DATABASE_URL=postgres://groupscout:groupscout@localhost:5432/groupscout
# DATABASE_URL=groupscout.db

# API Keys
CLAUDE_API_KEY=your_anthropic_key_here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
RESEND_API_KEY=re_your_resend_key_here
API_TOKEN=your_secure_bearer_token

# Permit URLs
RICHMOND_PERMITS_URL=https://www.richmond.ca/shared/assets/Building_Permits5342.pdf
DELTA_PERMITS_URL=https://delta.ca/building-permits

# Toggles
CREATIVEBC_ENABLED=true
CREATIVEBC_URL=https://www.creativebc.com/search-projects/in-production/
VCC_ENABLED=true
VCC_URL=https://www.vancouverconventioncentre.com/events/calendar
BCBID_ENABLED=true
NEWS_ENABLED=true
ANNOUNCEMENTS_ENABLED=true
EVENTBRITE_ENABLED=true

# Thresholds
ENRICHMENT_THRESHOLD=1
PRIORITY_ALERT_THRESHOLD=9
MIN_PERMIT_VALUE_CAD=500000

# Server
PORT=8080
DIGEST_DAYS=monday,wednesday
DIGEST_HOUR=9
